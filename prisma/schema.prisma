generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AlbumRanking {
  id String @id @default(uuid())

  albumId    String  @unique @map("album_id")
  spotifyId  String? @map("spotify_id")
  albumName  String  @map("album_name")
  artistName String? @map("artist_name")

  averageRating Float @default(0) @map("average_rating")
  totalRatings  Int   @default(0) @map("total_ratings")
  score         Float @default(0)
  position      Int?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("album_rankings")
}

model AlbumRatingSnapshot {
  id String @id @default(uuid())

  albumId String @map("album_id")
  userId  String @map("user_id")
  rating  Float

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([albumId, userId])
  @@map("album_rating_snapshots")
}
